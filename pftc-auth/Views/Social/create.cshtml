@model pftc_auth.Models.SocialMediaPost

@{
    ViewData["Title"] = "Create Post";
}

<h2>Write a New Post</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-controller="Social" asp-action="create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="PostContent" class="control-label fw-bold">What's on your mind?</label>
                <textarea asp-for="PostContent" class="form-control" rows="5" placeholder="Type your message here..."></textarea>
                <span asp-validation-for="PostContent" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">Publish Post</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}